{
  "$schema": "https://raw.githubusercontent.com/grafana/grafana/main/docs/sources/developers/plugins/plugin.schema.json",
  "type": "app",
  "name": "Showfast",
  "id": "cbperf-showfast-app",
  "backend": true,
  "executable": "gpx_showfast",
  "info": {
    "keywords": ["app"],
    "description": "",
    "author": {
      "name": "Cbperf"
    },
    "logos": {
      "small": "img/logo.svg",
      "large": "img/logo.svg"
    },
    "screenshots": [],
    "version": "%VERSION%",
    "updated": "%TODAY%"
  },
  "includes": [
    {
      "type": "page",
      "name": "Timelines",
      "path": "/a/%PLUGIN_ID%/timelines",
      "addToNav": true,
      "defaultNav": true
      
    },
    {
      "type": "page",
      "name": "Search",
      "path": "/a/%PLUGIN_ID%/search",
      "addToNav": true,
      "defaultNav": false
    }
  ],
  "dependencies": {
    "grafanaDependency": ">=12.3.0",
    "plugins": []
  }
}
